rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidWrongQuestion(data) {
      return data.userId is string &&
             data.originalQuestion is string &&
             data.originalQuestion.size() < 5000 &&
             data.knowledgePoint is string &&
             data.knowledgePoint.size() < 200 &&
             data.createdAt is string;
    }

    match /wrongQuestions/{questionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidWrongQuestion(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidWrongQuestion(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
